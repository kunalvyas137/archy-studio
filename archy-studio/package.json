{
  "name": "archy-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/server.js\"",
    "dev:ui": "vite",
    "dev:api": "node server/server.js",
    "build": "vite build",
    "build:typecheck": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder --mac --dir",
    "electron:pack": "npm run build && electron-builder --mac",
    "electron:dist": "npm run build && electron-builder --mac --publish=never"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.6",
    "@uiw/react-codemirror": "^4.25.9",
    "cors": "^2.8.5",
    "diff-match-patch": "^1.0.5",
    "express": "^4.21.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "simple-git": "^3.36.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.19",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "description": "Genesys Cloud Architect Scripting Studio",
  "author": "ARCHY Studio",
  "build": {
    "appId": "com.genesys.archy-studio",
    "productName": "ARCHY Studio",
    "copyright": "Copyright © 2025",
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        { "target": "zip", "arch": ["arm64", "x64"] },
        { "target": "dir", "arch": ["arm64"] }
      ],
      "darkModeSupport": true
    },
    "files": [
      "dist/**",
      "electron/**",
      "server/**",
      "node_modules/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    }
  }
}
